// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  COMPLETED
  DROPPED
}

enum Role {
  HO
  INCHARGE
  TEACHER
  STUDENT
}

model User {
  id            String   @id @default(uuid()) // Primary key
  name          String // User's full name
  email         String // User's email address
  emailVerified Boolean  @default(false) // Whether email is verified
  image         String? // Profile image URL
  createdAt     DateTime @default(now()) // Account creation timestamp
  updatedAt     DateTime @updatedAt // Last update timestamp

  // Relations
  sessions       Session[]
  accounts       Account[]
  studentProfile StudentProfile?

  // Permissions and Access
  role       Role      @default(STUDENT)
  banned     Boolean   @default(false)
  banReason  String?
  banExpires DateTime?

  // Branch Relation
  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  // Attributes
  @@unique([email])
  @@index([createdAt])
  @@index([role])
  @@index([branchId])
  @@map("user")
}

model Session {
  id        String   @id @default(uuid()) // Primary key
  expiresAt DateTime // Session expiration time
  token     String // Session authentication token
  createdAt DateTime @default(now()) // Session creation time
  updatedAt DateTime @updatedAt // Last update time
  ipAddress String? // IP address of the session
  userAgent String? // Browser/client user agent

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  // Access Control
  impersonatedBy String?

  // Attributes
  @@unique([token])
  @@index([userId])
  @@index([expiresAt])
  @@index([createdAt])
  @@map("session")
}

model Account {
  id                    String    @id @default(uuid()) // Primary key
  accountId             String // OAuth account identifier
  providerId            String // OAuth provider identifier
  accessToken           String? // OAuth access token
  refreshToken          String? // OAuth refresh token
  idToken               String? // OAuth ID token
  accessTokenExpiresAt  DateTime? // Access token expiration time
  refreshTokenExpiresAt DateTime? // Refresh token expiration time
  scope                 String? // OAuth granted scopes
  password              String? // Hashed password for credential auth
  createdAt             DateTime  @default(now()) // Account creation time
  updatedAt             DateTime  @updatedAt // Last update time

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  // Attributes
  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(uuid()) // Primary key
  identifier String // Verification identifier (email/phone)
  value      String // Verification code or token
  expiresAt  DateTime // Verification expiration time
  createdAt  DateTime @default(now()) // Verification creation time
  updatedAt  DateTime @updatedAt // Last update time

  // Attributes
  @@index([identifier])
  @@index([expiresAt])
  @@map("verification")
}

model StudentProfile {
  id                     String        @id @default(uuid()) // Primary key
  status                 StudentStatus @default(INACTIVE) // Student enrollment status
  officialName           String // Official/legal name
  occupation             String // Current occupation
  guardianName           String // Guardian's name
  sourcesOfIncome        String // Sources of income
  sourcesOfIncomeDetails String // Sources of income details
  fathersName            String // Father's name
  fathersOccupation      String // Father's occupation
  mothersName            String // Mother's name
  mothersOccupation      String // Mother's occupation
  dateOfBirth            DateTime // Date of birth
  lastQualification      String // Last qualification
  otherQualification     String? // Other qualification
  address                String // Address
  landmark               String // Landmark
  postOffice             String // Post office
  pinCode                String // Pin code
  district               String // District
  state                  String // State
  gender                 String // Gender
  religion               String // Religion
  category               String // Category
  branchId               String?
  branch                 Branch?       @relation(fields: [branchId], references: [id])
  aadharNumber           String // Aadhar number

  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Attributes
  @@unique([userId])
  @@index([status])
  @@index([branchId])
  @@map("student_profile")
}

model Branch {
  id        String   @id @default(uuid()) // Primary key
  name      String   @unique // e.g., "Dumdum", "Barasat"
  code      String?  @unique // e.g., "DUM", "BAR"
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) // Record creation time
  updatedAt DateTime @updatedAt // Last update time

  // Relations
  users           User[]
  studentProfiles StudentProfile[]

  // Attributes
  @@map("branch")
}

model Visitor {
  id                String   @id @default(uuid()) // Primary key
  candidateName     String // Visitor's full name
  candidatePhone    String // Phone number
  candidateWhatsApp String? // WhatsApp number
  candidateEmail    String? // Email address
  source            String // How they heard about us
  createdAt         DateTime @default(now()) // Record creation time
  updatedAt         DateTime @updatedAt // Last update time

  // Attributes
  @@map("visitor")
}
